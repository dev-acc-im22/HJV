// Matrimony Application - Complete Prisma Schema
// This schema defines all entities for a production-ready matrimony platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

/// Main user entity for authentication and account management
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  phone         String?       @unique
  passwordHash  String
  role          UserRole      @default(USER)
  accountStatus AccountStatus @default(PENDING)
  isVerified    Boolean       @default(false)
  isPremium     Boolean       @default(false)
  premiumExpiry DateTime?
  
  // Profile relationship
  profile       Profile?
  
  // Sent interactions
  sentInteractions     Interaction[]  @relation("SentInteractions")
  receivedInteractions Interaction[]  @relation("ReceivedInteractions")
  
  // Messages
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  
  // Notifications
  notifications Notification[]
  
  // Reports (as reporter)
  reportedBy    Report[]   @relation("ReportedBy")
  reportedUser  Report[]   @relation("ReportedUser")
  
  // Payments
  payments      Payment[]
  
  // Audit fields
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([email])
  @@index([phone])
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
}

enum AccountStatus {
  PENDING      // Awaiting verification
  ACTIVE       // Fully active account
  SUSPENDED    // Temporarily suspended
  DEACTIVATED  // User deactivated
  BANNED       // Permanently banned
}

// ============================================================================
// USER PROFILE
// ============================================================================

/// Complete profile information for matchmaking
model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Basic Information
  name            String
  gender          Gender
  dateOfBirth     DateTime
  height          Int           // in centimeters
  maritalStatus   MaritalStatus
  religion        String
  caste           String?
  motherTongue    String
  country         String
  state           String
  city            String
  bio             String?
  profileCreatedFor ProfileCreatedFor?
  
  // Physical Attributes
  bodyType        String?
  complexion      String?
  physicalStatus  PhysicalStatus @default(NORMAL)
  
  // Contact Information (Privacy Controlled)
  contactPhone    String?
  contactEmail    String?
  showPhone       Boolean @default(false)
  showEmail       Boolean @default(false)
  
  // Profile Completion
  profileCompletion Int @default(0)  // Percentage 0-100
  isProfileComplete Boolean @default(false)
  
  // Relationships
  educationCareer   EducationCareer?
  partnerPreference PartnerPreference?
  familyDetails     FamilyDetails?
  media             Media[]
  horoscope         Horoscope?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gender])
  @@index([religion])
  @@index([city])
  @@index([maritalStatus])
}

enum Gender {
  MALE
  FEMALE
}

enum MaritalStatus {
  NEVER_MARRIED
  DIVORCED
  WIDOWED
  AWAITING_DIVORCE
}

enum ProfileCreatedFor {
  SELF
  SON
  DAUGHTER
  BROTHER
  SISTER
  FRIEND
  RELATIVE
}

enum PhysicalStatus {
  NORMAL
  PHYSICALLY_CHALLENGED
}

// ============================================================================
// EDUCATION & CAREER
// ============================================================================

model EducationCareer {
  id            String  @id @default(cuid())
  profileId     String  @unique
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  // Education
  highestDegree   String?
  college         String?
  educationField  String?
  
  // Career
  employedIn      EmployedIn?
  occupation      String?
  organization    String?
  annualIncome    Int?        // In thousands (e.g., 500 = 5 LPA)
  incomeCurrency  String  @default("INR")
  
  // Work Location
  workCountry String?
  workState   String?
  workCity    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EmployedIn {
  GOVERNMENT
  PRIVATE
  BUSINESS
  DEFENSE
  SELF_EMPLOYED
  NOT_WORKING
  STUDENT
}

// ============================================================================
// FAMILY DETAILS
// ============================================================================

model FamilyDetails {
  id            String  @id @default(cuid())
  profileId     String  @unique
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  familyType      FamilyType?
  familyStatus    FamilyStatus?
  familyValues    FamilyValues?
  fatherOccupation String?
  motherOccupation String?
  brothersCount   Int     @default(0)
  brothersMarried Int     @default(0)
  sistersCount    Int     @default(0)
  sistersMarried  Int     @default(0)
  familyLocation  String?
  aboutFamily     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FamilyType {
  JOINT
  NUCLEAR
}

enum FamilyStatus {
  RICH
  UPPER_MIDDLE
  MIDDLE
  LOWER_MIDDLE
}

enum FamilyValues {
  TRADITIONAL
  MODERATE
  LIBERAL
  ORTHODOX
}

// ============================================================================
// PARTNER PREFERENCES
// ============================================================================

model PartnerPreference {
  id            String  @id @default(cuid())
  profileId     String  @unique
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  // Age Preference
  minAge        Int     @default(21)
  maxAge        Int     @default(40)
  
  // Height Preference (in cm)
  minHeight     Int     @default(140)
  maxHeight     Int     @default(200)
  
  // Marital Status
  maritalStatus String?   // Comma-separated values or JSON
  
  // Religion & Caste
  religion      String?
  caste         String?
  
  // Education & Career
  education     String?   // Comma-separated or JSON
  occupation    String?
  minIncome     Int?
  maxIncome     Int?
  employedIn    String?
  
  // Location
  country       String?
  state         String?
  city          String?
  
  // Other Preferences
  motherTongue  String?
  complexion    String?
  bodyType      String?
  physicalStatus PhysicalStatus?
  
  // Partner Description
  aboutPartner  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// MEDIA (Photos, Documents)
// ============================================================================

model Media {
  id            String        @id @default(cuid())
  profileId     String
  profile       Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  url           String
  thumbnailUrl  String?
  publicId      String?       // Cloud storage public ID
  
  mediaType     MediaType     @default(PHOTO)
  isPrimary     Boolean       @default(false)
  isBlurred     Boolean       @default(false)
  privacyLevel  PrivacyLevel  @default(PUBLIC)
  approvalStatus ApprovalStatus @default(PENDING)
  
  // Metadata
  fileSize      Int?
  width         Int?
  height        Int?
  caption       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([approvalStatus])
}

enum MediaType {
  PHOTO
  DOCUMENT
  HOROSCOPE
}

enum PrivacyLevel {
  PUBLIC              // Visible to all
  REGISTERED_USERS    // Visible to logged-in users
  PAID_MEMBERS        // Visible only to premium members
  ACCEPTED_MATCHES    // Visible only to accepted matches
  PRIVATE             // Not visible to anyone
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================================
// HOROSCOPE
// ============================================================================

model Horoscope {
  id            String  @id @default(cuid())
  profileId     String  @unique
  profile       Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  rashi         String?     // Moon Sign
  nakshatra     String?
  manglik       ManglikStatus @default(UNKNOWN)
  birthTime     String?
  birthPlace    String?
  horoscopeUrl  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ManglikStatus {
  YES
  NO
  ANSHIK    // Partial Manglik
  UNKNOWN
}

// ============================================================================
// INTERACTIONS (Interest, Shortlist, etc.)
// ============================================================================

model Interaction {
  id          String          @id @default(cuid())
  senderId    String
  sender      User            @relation("SentInteractions", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User            @relation("ReceivedInteractions", fields: [receiverId], references: [id], onDelete: Cascade)
  
  status      InteractionStatus @default(PENDING)
  type        InteractionType  @default(INTEREST)
  
  // Message sent with interest
  message     String?
  
  // Timestamps for different states
  viewedAt    DateTime?
  respondedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

enum InteractionStatus {
  PENDING     // Interest sent, awaiting response
  ACCEPTED    // Interest accepted
  DECLINED    // Interest declined
  SHORTLISTED // Profile shortlisted
  BLOCKED     // User blocked
}

enum InteractionType {
  INTEREST
  SHORTLIST
  BLOCK
}

// ============================================================================
// MESSAGES (Chat)
// ============================================================================

model Message {
  id          String      @id @default(cuid())
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String
  receiver    User        @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  content     String
  messageType MessageType @default(TEXT)
  mediaUrl    String?
  
  isRead      Boolean     @default(false)
  readAt      DateTime?
  
  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  title       String
  message     String
  data        String?           // JSON string for additional data
  
  isRead      Boolean           @default(false)
  readAt      DateTime?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

enum NotificationType {
  NEW_INTEREST
  INTEREST_ACCEPTED
  INTEREST_DECLINED
  NEW_MESSAGE
  PROFILE_VIEW
  PHOTO_REQUEST
  PREmium_EXPIRING
  SYSTEM
}

// ============================================================================
// REPORTS (User Reports & Moderation)
// ============================================================================

model Report {
  id              String      @id @default(cuid())
  reporterId      String
  reporter        User        @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId  String
  reportedUser    User        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  
  reason          ReportReason
  description     String?
  status          ReportStatus @default(PENDING)
  
  // Admin notes
  adminNotes      String?
  actionTaken     String?
  resolvedBy      String?
  resolvedAt      DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

enum ReportReason {
  FAKE_PROFILE
  INAPPROPRIATE_PHOTOS
  SCAM_OR_FRAUD
  HARASSMENT
  FAKE_CREDENTIALS
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

// ============================================================================
// PAYMENTS & SUBSCRIPTIONS
// ============================================================================

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Payment Details
  amount          Float
  currency        String        @default("INR")
  paymentMethod   String?
  transactionId   String?       @unique
  
  // Subscription Details
  planType        PlanType
  planDuration    Int           // in days
  startDate       DateTime
  endDate         DateTime
  
  status          PaymentStatus @default(PENDING)
  
  // Gateway Response
  gatewayResponse String?       // JSON
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum PlanType {
  FREE
  BASIC
  PREMIUM
  VIP
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================================================
// ADMIN AUDIT LOG
// ============================================================================

model AuditLog {
  id          String  @id @default(cuid())
  adminId     String
  action      String
  targetType  String  // User, Profile, Media, Report, etc.
  targetId    String?
  details     String? // JSON string
  
  ipAddress   String?
  userAgent   String?
  
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

// ============================================================================
// OTP VERIFICATION
// ============================================================================

model OtpVerification {
  id        String  @id @default(cuid())
  email     String?
  phone     String?
  otp       String
  purpose   OtpPurpose
  expiresAt DateTime
  
  isUsed    Boolean @default(false)
  usedAt    DateTime?
  
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  LOGIN
}

// ============================================================================
// SESSION TRACKING
// ============================================================================

model UserSession {
  id          String  @id @default(cuid())
  userId      String
  token       String  @unique
  deviceInfo  String?
  ipAddress   String?
  userAgent   String?
  
  isActive    Boolean @default(true)
  lastActive  DateTime @default(now())
  expiresAt   DateTime
  
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([token])
}
